model User {
  id                   Int                  @id @default(autoincrement())
  username             String               @unique @db.VarChar(50)
  email                String               @unique @db.VarChar(255)
  password             String?              @db.VarChar(255)
  fullname             String?              @db.VarChar(100)
  bio                  String?              @db.VarChar(160)
  avatarUrl            String?              @map("avatar_url") @db.Text
  coverUrl             String?              @map("cover_url") @db.Text
  isVerified           Boolean              @default(false) @map("is_verified")
  isEmailVerified      Boolean              @default(false) @map("is_email_verified")
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt            DateTime?            @map("deleted_at") @db.Timestamptz()
  oauthAccounts        OAuthAccount[]
  emailVerifications   EmailVerification[]
  passwordResets       PasswordReset[]
  refreshTokens        RefreshToken[]
  posts                Post[]
  postComments         PostComment[] 
  commentReplies       CommentReply[] 
  postLikes            PostLike[]
  followers            Follow[]             @relation("Following")
  following            Follow[]             @relation("Follower")
  blockedBy            UserBlock[]          @relation("Blocked")
  blocking             UserBlock[]          @relation("Blocker")
  notificationsSent    Notification[]       @relation("NotifSender")
  notificationsRecv    Notification[]       @relation("NotifReceiver")
  conversationsCreated Conversation[]       @relation("ConversationCreator")
  conversationMembers  ConversationMember[]
  messages             Message[]
  messageReads         MessageRead[]
  presence             UserPresence?
  commentLikes         CommentLike[]
  replyLikes           ReplyLike[]
  searchHistoryRecords SearchHistory[]      @relation("UserSearchOwner")
  searchedByRecords    SearchHistory[]      @relation("UserSearchTarget")

  @@index([username])
  @@index([email])
  @@index([deletedAt])
  @@index([isVerified, deletedAt])
  @@map("users")
}

model OAuthAccount {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  provider       String   @default("google") @db.VarChar(20)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  providerEmail  String?  @map("provider_email") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model EmailVerification {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  token      String    @unique @db.Text
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_verifications")
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  token     String    @unique @db.Text
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isVerified Boolean   @default(false) @map("is_verified")

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_resets")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  token      String    @unique @db.Text
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  deviceInfo String?   @map("device_info") @db.VarChar(255)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Follow {
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model UserBlock {
  blockerId Int      @map("blocker_id")
  blockedId Int      @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  @@id([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

model UserPresence {
  userId     Int       @id @map("user_id")
  isOnline   Boolean   @default(false) @map("is_online")
  lastSeenAt DateTime? @map("last_seen_at") @db.Timestamptz()
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("user_presence")
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  targetId  Int      @map("target_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

 
  user   User @relation("UserSearchOwner", fields: [userId], references: [id], onDelete: Cascade)
  target User @relation("UserSearchTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId]) 
  @@index([userId])
  @@index([userId, createdAt]) 
  @@map("search_histories")
}